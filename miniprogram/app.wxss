/* 全局样式 */
page {
  background-color: #f4f6fb;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #1a1a2e;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 0 0 60rpx;
}

/* 通用卡片 */
.card-box {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(21,101,192,0.07);
  margin: 0 32rpx 24rpx;
  padding: 36rpx 32rpx;
}

/* 通用按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: #1565C0;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}
.btn-primary[disabled] { background: #b0bec5; }

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #1565C0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 2rpx solid #1565C0;
}

/* 标签（订单状态小标签：待付款 / 制作中 / 已完成） */
.tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.35;
  vertical-align: middle;
}
.tag--pending {
  background: #fff3e0;
  color: #e65100;
  border: 1rpx solid rgba(230, 81, 0, 0.2);
}
.tag--claimed {
  background: #fff8e1;
  color: #ef6c00;
  border: 1rpx solid rgba(245, 127, 23, 0.22);
}
.tag--completed {
  background: #e8f5e9;
  color: #2e7d32;
  border: 1rpx solid rgba(46, 125, 50, 0.2);
}

/* 分割线 */
.divider { height: 1rpx; background: #f0f4fa; margin: 24rpx 0; }
