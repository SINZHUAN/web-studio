.page { min-height: 100vh; background: #f4f6fb; padding: 24rpx 0 60rpx; overflow: hidden; }

/* 整个订单详情页固定高度，禁止上下滚动 */
page {
  height: 100vh;
  overflow: hidden;
}

.loading-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 120rpx 40rpx; gap: 28rpx; color: #888;
}
.loading-ring {
  width: 80rpx; height: 80rpx;
  border: 6rpx solid #e3f2fd;
  border-top-color: #1565C0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 状态卡片：淡蓝底 + 蓝色边框 */
.status-card {
  margin: 0 32rpx 0;
  border-radius: 20rpx;
  padding: 32rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #e8f0fe;
  border: 2rpx solid #1565C0;
  box-shadow: 0 4rpx 18rpx rgba(21, 101, 192, 0.10);
}
.status-card__no  {
  font-size: 32rpx;
  font-weight: 700;
  color: #1565C0;
}
.status-card__tag { font-size: 20rpx; }

/* 区块标题 */
.section-title {
  font-size: 26rpx; color: #888; font-weight: 600;
  letter-spacing: 2rpx; margin: 32rpx 40rpx 16rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f4fa;
}
.info-row:last-child { border-bottom: none; }
.info-key { font-size: 26rpx; color: #888; flex-shrink: 0; margin-right: 20rpx; }
.info-val { font-size: 26rpx; color: #1a1a2e; font-weight: 500; text-align: right; flex: 1; }

/* ── 基本信息折叠卡片 ─────────────────────────────────────────────────────── */
.collapse-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(21,101,192,0.07);
  overflow: hidden;
}

.collapse-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 38rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.collapse-card__title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.collapse-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* 进度全部完成时标题旁边显示的绿色徽标 */
.progress-done-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: #2E7D32;
  background: #e8f5e9;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  letter-spacing: 0;
}

.collapse-card__arrow {
  font-size: 36rpx;
  color: #1565C0;
  font-weight: 700;
  transition: transform 0.2s;
  display: inline-block;
  transform: rotate(0deg);
}

.collapse-card__arrow--open {
  transform: rotate(90deg);
}

.collapse-card__body {
  padding: 0 32rpx 20rpx;
  border-top: 1rpx solid #f0f4fa;
}

/* ── 垂直流程图 ────────────────────────────────────────────────────────────── */
.flow-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 32rpx 32rpx;
  padding: 32rpx 32rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(21,101,192,0.07);
}

/* 嵌套在折叠卡片内时去掉独立卡片外框 */
.flow-card--inner {
  margin: 16rpx 0 8rpx;
  padding: 8rpx 0 0;
  box-shadow: none;
  border-radius: 0;
  background: transparent;
}

.flow-step {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
}

/* 左列：圆圈 + 连接线 */
.flow-step__left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 56rpx;
}

.flow-step__circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid #d0d8e8;
  background: #f4f7fb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.flow-step__circle--done {
  border-color: #1565C0;
  background: #1565C0;
}

.flow-step__seq {
  font-size: 22rpx;
  font-weight: 700;
  color: #bbb;
}

.flow-step__circle--done .flow-step__seq {
  color: #fff;
}

.flow-step__line {
  width: 3rpx;
  flex: 1;
  min-height: 32rpx;
  background: #e2e8f4;
  margin: 6rpx 0;
}

.flow-step__line--done {
  background: #1565C0;
}

/* 右列：内容 */
.flow-step__right {
  flex: 1;
  padding-bottom: 36rpx;
  padding-top: 8rpx;
  min-width: 0;
}

.flow-step__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.flow-step__info {
  flex: 1;
  min-width: 0;
}

.flow-step__title {
  font-size: 28rpx;
  color: #bbb;
  line-height: 1.5;
  display: block;
}

.flow-step__title--done {
  color: #1a1a2e;
  font-weight: 600;
}

.flow-step__time {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 6rpx;
  display: block;
}

/* 操作按钮 */
.flow-action-btn {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  white-space: nowrap;
}

.flow-action-btn--analysis {
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(21,101,192,0.28);
}

.flow-action-btn--preview {
  background: linear-gradient(135deg, #17c964, #0ab85c);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(10,184,92,0.28);
}

/* ═══════════════════════════════════════════════════════════════════════════
   成品预览大弹窗
═══════════════════════════════════════════════════════════════════════════ */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-box {
  width: 100%;
  height: 92vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 弹窗头部 */
.modal-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 0;
  border-bottom: 2rpx solid #f0f4fa;
  flex-shrink: 0;
}
.modal-tabs {
  flex: 1;
  display: flex;
  gap: 8rpx;
}
.modal-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #888;
  padding: 16rpx 0;
  border-bottom: 4rpx solid transparent;
  font-weight: 500;
}
.modal-tab--active {
  color: #1565C0;
  border-bottom-color: #1565C0;
  font-weight: 700;
}
.modal-close {
  width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #aaa;
  flex-shrink: 0;
}

/* swiper 占满剩余高度 */
.modal-swiper {
  flex: 1;
  height: 0;   /* 配合 flex:1 撑满 */
}

.modal-scroll {
  height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 空提示 */
.modal-empty {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 80rpx 40rpx;
}

/* ─── 图片 + 水印 ─────────────────────────────────────────────────────────── */
.img-wrap {
  position: relative;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.10);
}

.modal-img {
  width: 100%;
  display: block;
}

.wm-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.wm-text {
  position: absolute;
  font-size: 22rpx;
  color: #333;
  opacity: 0.14;
  transform: rotate(-35deg);
  white-space: nowrap;
  letter-spacing: 4rpx;
  font-weight: 600;
}

/* ─── 优化解析 ──────────────────────────────────────────────────────────── */
.analysis-score-wrap {
  display: flex; align-items: center; gap: 32rpx;
  background: #f8faff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.analysis-score-circle {
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1565C0, #1976D2);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  flex-shrink: 0;
}
.analysis-score-val  { font-size: 36rpx; font-weight: 700; color: #fff; line-height: 1; }
.analysis-score-unit { font-size: 20rpx; color: rgba(255,255,255,0.8); }
.analysis-score-info { flex: 1; }
.analysis-score-level { display: block; font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.analysis-score-hint  { font-size: 22rpx; color: #888; margin-top: 4rpx; }

/* ─── 润色解析报告章节 ────────────────────────────────────────────────────── */
.ar-section {
  background: #f8faff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.ar-section__title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1565C0;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #1565C0;
}
.ar-section__text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
}
.ar-improvement {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 14rpx;
}
.ar-improvement:last-child { margin-bottom: 0; }
.ar-improvement__num {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #e8f0fe;
  color: #1565C0;
  font-size: 22rpx;
  font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  line-height: 40rpx;
  text-align: center;
}
.ar-improvement__text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  flex: 1;
}


/* ─── 分析报告弹窗（am = analysis modal） ───────────────────────────────── */
.am-box {
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.am-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.am-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.am-score-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx 20rpx;
  background: #f8faff;
  border-bottom: 1rpx solid #eaf0fb;
}

.am-score-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.am-score-val {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.am-score-unit {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 2rpx;
}

.am-score-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.am-score-level {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.am-score-hint {
  font-size: 24rpx;
  color: #888;
}

.am-scroll {
  flex: 1;
  height: 0;   /* 微信小程序 scroll-view scroll-y 必须有固定高度才能滚动 */
}

.am-scroll-inner {
  padding: 24rpx 32rpx;
}

.am-item {
  background: #f8f9ff;
  border-radius: 16rpx;
  border-left: 6rpx solid #1565C0;
  padding: 20rpx 24rpx;
  margin-bottom: 18rpx;
}

.am-item:last-child { margin-bottom: 0; }

.am-item__title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1565C0;
  margin-bottom: 10rpx;
}

.am-item__content {
  font-size: 25rpx;
  color: #444;
  line-height: 1.75;
}

/* ── 五维雷达图（分析报告弹窗内） ───────────────────────────────── */
.am-radar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f8ff;
  border-radius: 20rpx;
  padding: 24rpx 0 20rpx;
  margin-bottom: 24rpx;
}

.am-radar-canvas {
  width: 640rpx;
  height: 600rpx;
  display: block;
}

/* 图例 */
.am-radar-legend {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 12rpx;
}

.am-radar-legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.am-radar-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.am-radar-dot--industry { background: #2196F3; }
.am-radar-dot--good     { background: #4CAF50; }
.am-radar-dot--mid      { background: #FF9800; }
.am-radar-dot--low      { background: #F44336; }

.am-radar-legend-text {
  font-size: 22rpx;
  color: #666;
}

/* 五维数值说明条 */
.am-radar-strip {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  width: 100%;
  padding: 0 16rpx;
  margin-top: 8rpx;
}

.am-radar-strip-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.am-radar-strip-label {
  font-size: 20rpx;
  color: #888;
}

.am-radar-strip-val {
  font-size: 24rpx;
  font-weight: 600;
  color: #2196F3;
}

.am-radar-val--good { color: #4CAF50; }
.am-radar-val--mid  { color: #FF9800; }
.am-radar-val--low  { color: #F44336; }

/* 比较结论文本 */
.am-radar-compare {
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
  padding: 14rpx 32rpx 4rpx;
  letter-spacing: 1rpx;
}

.am-radar-compare--ahead  { color: #4CAF50; }
.am-radar-compare--behind { color: #F44336; }
.am-radar-compare--equal  { color: #888888; }

/* ── 成品下载 3×2 网格 ────────────────────────────────────────────────────── */

.result-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  padding: 0 32rpx 32rpx;
}

.result-cell {
  width: calc((100% - 36rpx) / 3);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx 22rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.07);
  gap: 10rpx;
  min-height: 180rpx;
}

.result-cell--empty {
  background: transparent;
  box-shadow: none;
}

.result-cell--inactive {
  opacity: 0.55;
}

.result-cell__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f4fa;
  overflow: hidden;
}

.result-cell__icon-img {
  width: 64rpx;
  height: 64rpx;
  display: block;
}

.result-cell__label {
  font-size: 22rpx;
  color: #888;
  text-align: center;
  line-height: 1.3;
}

.result-cell__label--active {
  color: #333;
  font-weight: 500;
}

.result-cell__badge {
  font-size: 18rpx;
  color: #1565C0;
  background: #e3f0ff;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
}

.result-cell__badge--na {
  color: #aaa;
  background: #f2f2f2;
}
